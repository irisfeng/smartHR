# === SmartHR Production Config ===
# Copy to .env and fill in actual values

# Environment
ENV=prod

# JWT secret (deploy.sh auto-generates this)
SECRET_KEY=change-me

# Database
POSTGRES_USER=smarthr
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=smarthr

# Data directory (ECS data disk mount point)
DATA_DIR=/data

# CORS (use IP first, switch to domain after ICP filing)
ALLOWED_ORIGINS=https://YOUR_ECS_PUBLIC_IP

# MinerU PDF parsing
MINERU_API_KEY=your-mineru-key

# DeepSeek AI screening
AI_API_URL=https://api.deepseek.com/v1
AI_API_KEY=your-deepseek-key
AI_MODEL=deepseek-chat
